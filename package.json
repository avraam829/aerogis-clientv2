{
  "name": "aerogis-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite build && electron electron/main.js",
    "build": "vite build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.aerogis.app",
    "productName": "AeroGIS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@ifrunistuttgart/node-mavlink": "github:ifrunistuttgart/node-mavlink",
    "@turf/turf": "^7.2.0",
    "mapbox-gl": "^3.10.0",
    "mavlink": "^1.0.1",
    "node-mavlink": "^2.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "serialport": "^13.0.0",
    "socket.io-client": "^4.8.1",
    "turf": "^3.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.3.9",
    "eslint": "^9.19.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "vite": "^6.1.0",
    "vite-plugin-electron": "^0.29.0"
  }
}
